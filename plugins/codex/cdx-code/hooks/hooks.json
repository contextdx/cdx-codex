{
  "description": "ContextDX hooks: session status, cdx display guard, intents resolve gate",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/scripts/check-config.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/cdx-resolve-gate.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/cdx-display-guard.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
