{
  "description": "ContextDX hooks for session status",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/scripts/check-config.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
